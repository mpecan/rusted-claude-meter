{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the popover (main) and Settings windows",
  "windows": ["main", "settings"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "x-apple.systempreferences:*" }]
    }
  ]
}
