# Supply-chain hardening. Block package lifecycle scripts (preinstall /
# install / postinstall) from running on `npm ci`/`npm install`. This is the
# primary infection vector for self-replicating npm worms (e.g. Shai-Hulud):
# a compromised dependency ships a malicious postinstall that harvests
# credentials the moment it is installed. Our locked tree currently has zero
# lifecycle scripts, so this changes nothing about our build today — it just
# denies that vector to any future compromised transitive dependency, locally
# and in CI. If a legitimately-needed dependency ever requires a build step,
# run it explicitly (`npm rebuild <pkg>`) after reviewing it.
ignore-scripts=true
